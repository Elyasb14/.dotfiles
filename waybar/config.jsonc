{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["custom/hello"],
    "modules-center": ["clock"], 
    "modules-right": [ "cpu", "battery", "tray"],

    "custom/hello": {
        "format": "from my dotfiles"
    },

    "clock": {
        "format": "{:%H:%M:%S}"
    }
}
