{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["network"],
    "modules-center": ["clock"], 
    "modules-right": [  "pulseaudio", "cpu", "battery", "tray"],

    "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}"
    },

    "cpu": {
        "format": "CPU: {usage}%"
    },

    "network": {
        "format": "{ifname}: {ipaddr}/{cidr} {signaldBm}dBm"
    },

    "battery": {
        "format": "Battery: {capacity}% {icon}",
        "format-icons": ["", "", "", "", ""],
    },

    "pulseaudio": {
        "format": "Vol: {volume}%"
    }
}
